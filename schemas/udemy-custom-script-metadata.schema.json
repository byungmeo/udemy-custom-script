{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Udemy Custom Script Metadata",
  "description": "Schema for the JSON metadata block embedded at the top of a Udemy custom script file.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format_version",
    "provider",
    "identity",
    "course",
    "transcript",
    "section",
    "lecture"
  ],
  "properties": {
    "format_version": {
      "type": "integer",
      "const": 1,
      "description": "Custom script format version."
    },
    "provider": {
      "type": "string",
      "const": "udemy",
      "description": "Transcript source provider."
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "course": {
      "$ref": "#/$defs/course"
    },
    "transcript": {
      "$ref": "#/$defs/transcript"
    },
    "section": {
      "$ref": "#/$defs/section"
    },
    "lecture": {
      "$ref": "#/$defs/lecture"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "language_code": {
      "type": "string",
      "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$",
      "description": "Language code. BCP 47 compatible values are recommended."
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Lowercase hyphen-separated slug."
    },
    "lookup_key": {
      "type": "string",
      "pattern": "^udemy__course-.+__section-.+__lecture-.+__lang-.+$",
      "description": "Deterministic lookup key derived from identity fields."
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lookup_key",
        "course_id",
        "section_index",
        "lecture_id",
        "lecture_index",
        "transcript_language"
      ],
      "properties": {
        "lookup_key": {
          "$ref": "#/$defs/lookup_key"
        },
        "course_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "course_slug": {
          "$ref": "#/$defs/slug"
        },
        "section_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "section_index": {
          "type": "integer",
          "minimum": 0,
          "description": "0 means the section index could not be reliably resolved."
        },
        "lecture_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "lecture_index": {
          "type": "integer",
          "minimum": 0,
          "description": "0 means the lecture index could not be reliably resolved."
        },
        "lecture_slug": {
          "$ref": "#/$defs/slug"
        },
        "transcript_language": {
          "$ref": "#/$defs/language_code"
        }
      }
    },
    "course": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "level",
        "level_label",
        "default_language",
        "caption_available"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "description": {
          "type": "string",
          "description": "Course description text. Preserve paragraph breaks with \\n\\n when available."
        },
        "level": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Stable level code. Examples: beginner, intermediate, expert, all_levels, unknown."
        },
        "level_label": {
          "$ref": "#/$defs/non_empty_string",
          "description": "Display label captured from Udemy or derived from the level code."
        },
        "default_language": {
          "$ref": "#/$defs/language_code"
        },
        "caption_available": {
          "type": "boolean"
        }
      }
    },
    "transcript": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "updated_at"
      ],
      "properties": {
        "language": {
          "$ref": "#/$defs/language_code"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last known transcript update timestamp in ISO 8601 format."
        }
      }
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "lecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
